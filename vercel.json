{
  "version": 2,
  "buildCommand": "npm install --legacy-peer-deps --prefix frontend && npm run build --prefix frontend",
  "outputDirectory": "frontend/.next",
  "installCommand": "npm install --legacy-peer-deps --prefix frontend",
  "framework": "nextjs",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/backend/src/index.js" }
  ]
}
