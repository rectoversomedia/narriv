{
  "name": "backend",
  "version": "1.0.0",
  "description": "Narriv Backend API",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:js": "nodemon src/index.js",
    "start": "node dist/index.js",
    "build": "tsc",
    "build:bundle": "node build.mjs",
    "build:watch": "tsc --watch",
    "test": "cross-env NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "load:smoke": "node tests/load/run-k6.js smoke",
    "load:baseline": "node tests/load/run-k6.js baseline",
    "load:stress": "node tests/load/run-k6.js stress",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch"
  },
  "keywords": [
    "narriv",
    "api",
    "narrative-intelligence"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "apify-client": "^2.23.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.75.2",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "lodash.isequal": "^4.5.0",
    "openai": "^6.34.0",
    "proxy-agent": "^6.5.0",
    "resend": "^6.12.4",
    "uuid": "^9.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.15.3",
    "@types/uuid": "^10.0.0",
    "cross-env": "^10.1.0",
    "esbuild": "^0.28.1",
    "jest": "^30.4.2",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vercel": "^56.3.1"
  }
}
