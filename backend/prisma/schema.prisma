// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String               @id @default(uuid())
  name                String?
  email               String               @unique
  password            String // the summary.md uses password_hash, but we'll stick to 'password' or use password_hash. Let's use password to be simple.
  failedLoginAttempts Int                  @default(0)
  lockedUntil         DateTime?
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  oauthAccounts           OAuthAccount[]
  auditLogs           AuditLog[]
  emailVerified       DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  memberships      WorkspaceMember[]
  appNotifications AppNotification[]

  @@index([createdAt])
}

model Workspace {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members               WorkspaceMember[]
  settings              WorkspaceSettings?
  notificationSettings  WorkspaceNotificationSettings?
  sources               Source[]
  ingestionJobs         IngestionJob[]
  rawDocuments          RawDocument[]
  signals               Signal[]
  aiAnalysisFailureLogs AIAnalysisFailureLog[]
  alerts                Alert[]
  narrativeClusters     NarrativeCluster[]
  reports               Report[]
  actionPlans           ActionPlan[]
  generatedAssets       GeneratedAsset[]
  aiVisibilityResults   AIVisibilityResult[]
  promptTestRuns        PromptTestRun[]
  aiFeedback            AIFeedback[]
  cases                 Case[]
  integrations          Integration[]
  AppNotification       AppNotification[]
}

model WorkspaceSettings {
  id                String   @id @default(uuid())
  workspaceId       String   @unique
  brandName         String?
  industry          String?
  timezone          String?
  notificationEmail String?
  whatsappPIC       String?
  logoUrl           String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model WorkspaceNotificationSettings {
  id                      String   @id @default(uuid())
  workspaceId             String   @unique
  emailEnabled            Boolean  @default(true)
  whatsappEnabled         Boolean  @default(false)
  escalationNotifications Boolean  @default(true)
  reminderNotifications   Boolean  @default(true)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model WorkspaceMember {
  id          String   @id @default(uuid())
  userId      String
  workspaceId String
  role        String // (admin, analyst, viewer)
  createdAt   DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id])
  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@unique([userId, workspaceId])
  @@index([workspaceId])
  @@index([userId])
}

model Source {
  id          String   @id @default(uuid())
  workspaceId String
  name        String
  type        String // (news, web, forum, social, video, podcast)
  actorId     String?
  inputConfig Json?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  workspace     Workspace      @relation(fields: [workspaceId], references: [id])
  ingestionJobs IngestionJob[]
  rawDocuments  RawDocument[]

  @@index([workspaceId, isActive, createdAt])
  @@index([workspaceId, type])
  @@index([workspaceId, name])
}

model IngestionJob {
  id           String    @id @default(uuid())
  workspaceId  String
  sourceId     String
  runId        String?
  status       String
  startedAt    DateTime  @default(now())
  finishedAt   DateTime?
  errorMessage String?

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  source    Source    @relation(fields: [sourceId], references: [id])

  @@index([workspaceId, status, startedAt])
  @@index([sourceId, startedAt])
}

model RawDocument {
  id          String    @id @default(uuid())
  workspaceId String
  sourceId    String
  externalId  String?
  title       String?
  content     String
  url         String?
  author      String?
  sourceName  String?
  sourceType  String?
  platform    String?
  publishedAt DateTime?
  capturedAt  DateTime  @default(now())
  metadata    Json?

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  source    Source    @relation(fields: [sourceId], references: [id])
  signals   Signal[]

  @@index([workspaceId, capturedAt])
  @@index([sourceId, capturedAt])
  @@index([workspaceId, sourceType, capturedAt])
  @@index([workspaceId, externalId])
}

model Signal {
  id            String    @id @default(uuid())
  workspaceId   String
  rawDocumentId String?
  title         String?
  content       String
  sourceName    String?
  sourceType    String?
  platform      String?
  url           String?
  publishedAt   DateTime?
  capturedAt    DateTime  @default(now())
  region        String?
  language      String?
  dedupeHash    String?

  // NOTE: Based on old code, the router expected sentiment directly in the Signal model
  // I will add sentiment to signal as well to prevent breaking old code, or I can rely on SignalAnalysis
  sentiment String?

  workspace               Workspace                @relation(fields: [workspaceId], references: [id])
  rawDocument             RawDocument?             @relation(fields: [rawDocumentId], references: [id])
  analyses                SignalAnalysis[]
  aiAnalysisFailureLogs   AIAnalysisFailureLog[]
  narrativeClusterSignals NarrativeClusterSignal[]

  @@index([workspaceId, capturedAt])
  @@index([workspaceId, sentiment, capturedAt])
  @@index([workspaceId, platform, capturedAt])
  @@index([rawDocumentId])
  @@index([workspaceId, dedupeHash])
}

model SignalAnalysis {
  id                String   @id @default(uuid())
  signalId          String
  contentHash       String?
  sentiment         String?
  narrativeType     String?
  stakeholder       String?
  impact            String?
  summary           String?
  recommendedAction String?
  confidenceScore   Float?
  createdAt         DateTime @default(now())

  signal Signal @relation(fields: [signalId], references: [id])

  @@index([signalId, createdAt])
  @@index([contentHash])
  @@index([sentiment])
  @@index([impact])
}

model Alert {
  id              String          @id @default(uuid())
  workspaceId     String
  type            String // (risk, opportunity, positioning)
  severity        String // (low, medium, high, critical)
  title           String
  whatHappened    String?
  whyItMatters    String?
  whatToDo        String?
  assignedTo      String?
  assignedTeam    String?
  deadline        DateTime?
  escalationLevel EscalationLevel @default(medium)
  workflowStatus  String? // (todo, in_progress, blocked, done)
  status          String          @default("open") // (open, acknowledged, in_progress, resolved)
  createdAt       DateTime        @default(now())

  workspace   Workspace    @relation(fields: [workspaceId], references: [id])
  actionPlans ActionPlan[]

  @@index([workspaceId, status, createdAt])
  @@index([workspaceId, severity, createdAt])
  @@index([workspaceId, type, createdAt])
}

model NarrativeCluster {
  id            String       @id @default(uuid())
  workspaceId   String
  title         String
  description   String?
  mainNarrative String?
  sentiment     String? // dominant sentiment
  impact        ImpactLevel? // low, medium, high, critical
  signalCount   Int          @default(0)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  workspace               Workspace                @relation(fields: [workspaceId], references: [id])
  actionPlans             ActionPlan[]
  narrativeClusterSignals NarrativeClusterSignal[]

  @@index([workspaceId, updatedAt])
  @@index([workspaceId, impact, updatedAt])
  @@index([workspaceId, sentiment, updatedAt])
}

model NarrativeClusterSignal {
  id                 String   @id @default(uuid())
  narrativeClusterId String
  signalId           String
  createdAt          DateTime @default(now())

  narrativeCluster NarrativeCluster @relation(fields: [narrativeClusterId], references: [id])
  signal           Signal           @relation(fields: [signalId], references: [id])

  @@unique([narrativeClusterId, signalId])
  @@index([signalId])
}

enum ImpactLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum EscalationLevel {
  low
  medium
  high
  critical
}

model Report {
  id          String    @id @default(uuid())
  workspaceId String
  title       String
  periodStart DateTime?
  periodEnd   DateTime?
  summary     String?
  exportUrl   String?
  createdAt   DateTime  @default(now())

  workspace Workspace      @relation(fields: [workspaceId], references: [id])
  exports   ReportExport[]

  @@index([workspaceId, createdAt])
  @@index([workspaceId, title])
}

model ActionPlan {
  id              String          @id @default(uuid())
  workspaceId     String
  alertId         String?
  clusterId       String?
  title           String
  option1         String?
  option2         String?
  option3         String?
  assignedTo      String?
  assignedTeam    String?
  deadline        DateTime?
  escalationLevel EscalationLevel @default(medium)
  workflowStatus  String? // (todo, in_progress, blocked, done)
  createdAt       DateTime        @default(now())

  workspace       Workspace         @relation(fields: [workspaceId], references: [id])
  alert           Alert?            @relation(fields: [alertId], references: [id])
  cluster         NarrativeCluster? @relation(fields: [clusterId], references: [id])
  generatedAssets GeneratedAsset[]

  @@index([workspaceId, createdAt])
  @@index([alertId])
  @@index([clusterId])
}

model GeneratedAsset {
  id           String   @id @default(uuid())
  workspaceId  String
  actionPlanId String
  type         String // (press_release, influencer_brief, holding_statement, faq, internal_memo, campaign_brief)
  title        String
  content      String
  createdAt    DateTime @default(now())

  workspace  Workspace  @relation(fields: [workspaceId], references: [id])
  actionPlan ActionPlan @relation(fields: [actionPlanId], references: [id])

  @@index([workspaceId, createdAt])
  @@index([actionPlanId])
}

model AIVisibilityResult {
  id                    String   @id @default(uuid())
  workspaceId           String
  engineName            String // (chatgpt, gemini, perplexity, copilot, claude, etc.)
  visibilityScore       Float // 0.0 - 100.0
  brandPresenceRate     Float // 0.0 - 1.0 (percentage as decimal)
  competitorMentionRate Float // 0.0 - 1.0 (percentage as decimal)
  queryUsed             String? // the prompt/query sent to the AI engine
  rawResponse           Json? // full raw response for auditing
  metadata              Json? // additional context (model version, tokens, etc.)
  createdAt             DateTime @default(now())

  workspace      Workspace       @relation(fields: [workspaceId], references: [id])
  promptTestRuns PromptTestRun[]

  @@index([workspaceId, createdAt])
  @@index([workspaceId, engineName, createdAt])
}

model PromptTestRun {
  id                   String   @id @default(uuid())
  workspaceId          String
  aiVisibilityResultId String
  prompt               String
  engine               String
  brand                String
  competitor           String
  brandTone            String
  compTone             String
  highlighted          Boolean  @default(false)
  createdAt            DateTime @default(now())

  workspace          Workspace          @relation(fields: [workspaceId], references: [id])
  aiVisibilityResult AIVisibilityResult @relation(fields: [aiVisibilityResultId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@index([workspaceId, engine, createdAt])
  @@index([aiVisibilityResultId])
}

model AIFeedback {
  id             String   @id @default(uuid())
  workspaceId    String
  targetType     String // (signal_analysis, alert, action_plan, cluster)
  targetId       String // ID of the entity being rated
  action         String // (accepted, edited, rejected)
  originalOutput Json? // the AI output before feedback
  editedOutput   Json? // user's corrected version (if edited)
  reason         String? // optional reason for rejection/edit
  userId         String? // who gave the feedback
  createdAt      DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId, createdAt])
  @@index([workspaceId, targetType, targetId])
  @@index([workspaceId, action, createdAt])
  @@index([userId, createdAt])
}

model AIAnalysisFailureLog {
  id           String   @id @default(uuid())
  workspaceId  String
  signalId     String
  errorMessage String
  rawAttempt1  String?
  rawAttempt2  String?
  createdAt    DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  signal    Signal    @relation(fields: [signalId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@index([signalId])
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([expiresAt])
  @@index([revokedAt])
}

model PasswordResetToken {
  id         String    @id @default(uuid())
  userId     String
  tokenHash  String    @unique
  codeHash   String
  expiresAt  DateTime
  verifiedAt DateTime?
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([expiresAt])
  @@index([usedAt])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  event     String
  metadata  Json?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([event, createdAt])
}

model ReportExport {
  id           String    @id @default(uuid())
  reportId     String
  status       String // queued, running, completed, failed
  format       String // json, pdf
  fileName     String?
  fileContent  Json?
  signedToken  String?   @unique
  signedUrl    String?
  errorMessage String?
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId, status])
  @@index([status, createdAt])
  @@index([expiresAt])
}

model Case {
  id           String    @id @default(uuid())
  workspaceId  String
  title        String
  description  String?
  status       String    @default("open") // open, in_progress, resolved, closed
  priority     String    @default("medium") // low, medium, high, critical
  sourceType   String? // alert, narrative, manual
  sourceId     String? // ID of the source alert/narrative
  assignedTo   String?
  assignedTeam String?
  deadline     DateTime?
  resolution   String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, status])
  @@index([workspaceId, createdAt])
  @@index([workspaceId, priority])
}

model Integration {
  id           String    @id @default(uuid())
  workspaceId  String
  name         String
  platform     String // slack, teams, email, webhook, etc.
  status       String    @default("active") // active, inactive, error
  config       Json? // platform-specific configuration
  lastSyncAt   DateTime?
  errorMessage String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, platform])
  @@index([workspaceId, status])
}

model TokenUsage {
  id             String   @id @default(uuid())
  workspaceId    String
  date           DateTime @db.Date
  model          String
  totalTokens    Int      @default(0)
  callCount      Int      @default(0)
  totalLatencyMs Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([workspaceId, date, model])
  @@index([workspaceId, date])
}

model AppNotification {
  id          String   @id @default(uuid())
  workspaceId String
  userId      String?
  type        String
  title       String
  message     String
  link        String?
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([userId])
  @@index([createdAt])
}


model EmailVerificationToken {
  id         String    @id @default(uuid())
  userId     String
  codeHash   String
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([expiresAt])
  @@index([usedAt])
}


model OAuthAccount {
  id                String   @id @default(uuid())
  userId            String
  provider          String   // e.g. "google", "microsoft"
  providerAccountId String   // ID from the provider
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}
