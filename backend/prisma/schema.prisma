// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js" 
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid())
  name          String?
  email         String   @unique
  password      String   // the summary.md uses password_hash, but we'll stick to 'password' or use password_hash. Let's use password to be simple.
  failedLoginAttempts Int @default(0)
  lockedUntil   DateTime?
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  memberships WorkspaceMember[]
}

model Workspace {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members          WorkspaceMember[]
  sources          Source[]
  ingestionJobs    IngestionJob[]
  rawDocuments     RawDocument[]
  signals          Signal[]
  aiAnalysisFailureLogs AIAnalysisFailureLog[]
  alerts           Alert[]
  narrativeClusters NarrativeCluster[]
  reports          Report[]
  actionPlans      ActionPlan[]
  generatedAssets  GeneratedAsset[]
  aiVisibilityResults AIVisibilityResult[]
  promptTestRuns    PromptTestRun[]
  aiFeedback        AIFeedback[]
}

model WorkspaceMember {
  id          String @id @default(uuid())
  userId      String
  workspaceId String
  role        String // (admin, analyst, viewer)
  createdAt   DateTime @default(now())

  user        User      @relation(fields: [userId], references: [id])
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
}

model Source {
  id            String   @id @default(uuid())
  workspaceId   String
  name          String
  type          String   // (news, web, forum, social, video, podcast)
  actorId       String?
  inputConfig   Json?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  workspace     Workspace @relation(fields: [workspaceId], references: [id])
  ingestionJobs IngestionJob[]
  rawDocuments  RawDocument[]
}

model IngestionJob {
  id            String   @id @default(uuid())
  workspaceId   String
  sourceId      String
  runId         String?
  status        String
  startedAt     DateTime @default(now())
  finishedAt    DateTime?
  errorMessage  String?

  workspace     Workspace @relation(fields: [workspaceId], references: [id])
  source        Source    @relation(fields: [sourceId], references: [id])
}

model RawDocument {
  id            String   @id @default(uuid())
  workspaceId   String
  sourceId      String
  externalId    String?
  title         String?
  content       String
  url           String?
  author        String?
  sourceName    String?
  sourceType    String?
  platform      String?
  publishedAt   DateTime?
  capturedAt    DateTime @default(now())
  metadata      Json?

  workspace     Workspace @relation(fields: [workspaceId], references: [id])
  source        Source    @relation(fields: [sourceId], references: [id])
  signals       Signal[]
}

model Signal {
  id            String   @id @default(uuid())
  workspaceId   String
  rawDocumentId String?
  title         String?
  content       String
  sourceName    String?
  sourceType    String?
  platform      String?
  url           String?
  publishedAt   DateTime?
  capturedAt    DateTime @default(now())
  region        String?
  language      String?
  dedupeHash    String?
  
  // NOTE: Based on old code, the router expected sentiment directly in the Signal model
  // I will add sentiment to signal as well to prevent breaking old code, or I can rely on SignalAnalysis
  sentiment     String?

  workspace     Workspace @relation(fields: [workspaceId], references: [id])
  rawDocument   RawDocument? @relation(fields: [rawDocumentId], references: [id])
  analyses      SignalAnalysis[]
  aiAnalysisFailureLogs AIAnalysisFailureLog[]
  narrativeClusterSignals NarrativeClusterSignal[]
}

model SignalAnalysis {
  id                String   @id @default(uuid())
  signalId          String
  sentiment         String?
  narrativeType     String?
  stakeholder       String?
  impact            String?
  summary           String?
  recommendedAction String?
  confidenceScore   Float?
  createdAt         DateTime @default(now())

  signal            Signal @relation(fields: [signalId], references: [id])
}

model Alert {
  id            String   @id @default(uuid())
  workspaceId   String
  type          String   // (risk, opportunity, positioning)
  severity      String   // (low, medium, high, critical)
  title         String
  whatHappened  String?
  whyItMatters  String?
  whatToDo      String?
  status        String   @default("open") // (open, acknowledged, in_progress, resolved)
  createdAt     DateTime @default(now())

  workspace     Workspace @relation(fields: [workspaceId], references: [id])
  actionPlans   ActionPlan[]
}

model NarrativeCluster {
  id             String   @id @default(uuid())
  workspaceId    String
  title          String
  description    String?
  mainNarrative  String?
  sentiment      String?      // dominant sentiment
  impact         ImpactLevel? // low, medium, high, critical
  signalCount    Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  workspace      Workspace @relation(fields: [workspaceId], references: [id])
  actionPlans    ActionPlan[]
  narrativeClusterSignals NarrativeClusterSignal[]
}

model NarrativeClusterSignal {
  id                 String @id @default(uuid())
  narrativeClusterId String
  signalId           String
  createdAt          DateTime @default(now())

  narrativeCluster   NarrativeCluster @relation(fields: [narrativeClusterId], references: [id])
  signal             Signal           @relation(fields: [signalId], references: [id])

  @@unique([narrativeClusterId, signalId])
}

enum ImpactLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model Report {
  id            String   @id @default(uuid())
  workspaceId   String
  title         String
  periodStart   DateTime?
  periodEnd     DateTime?
  summary       String?
  exportUrl     String?
  createdAt     DateTime @default(now())

  workspace     Workspace @relation(fields: [workspaceId], references: [id])
}

model ActionPlan {
  id            String   @id @default(uuid())
  workspaceId   String
  alertId       String?
  clusterId     String?
  title         String
  option1       String?
  option2       String?
  option3       String?
  createdAt     DateTime @default(now())

  workspace     Workspace @relation(fields: [workspaceId], references: [id])
  alert         Alert?    @relation(fields: [alertId], references: [id])
  cluster       NarrativeCluster? @relation(fields: [clusterId], references: [id])
  generatedAssets GeneratedAsset[]
}

model GeneratedAsset {
  id            String   @id @default(uuid())
  workspaceId   String
  actionPlanId  String
  type          String   // (press_release, influencer_brief, holding_statement, faq, internal_memo, campaign_brief)
  title         String
  content       String
  createdAt     DateTime @default(now())

  workspace     Workspace  @relation(fields: [workspaceId], references: [id])
  actionPlan    ActionPlan @relation(fields: [actionPlanId], references: [id])
}

model AIVisibilityResult {
  id                    String   @id @default(uuid())
  workspaceId           String
  engineName            String   // (chatgpt, gemini, perplexity, copilot, claude, etc.)
  visibilityScore       Float    // 0.0 - 100.0
  brandPresenceRate     Float    // 0.0 - 1.0 (percentage as decimal)
  competitorMentionRate Float    // 0.0 - 1.0 (percentage as decimal)
  queryUsed             String?  // the prompt/query sent to the AI engine
  rawResponse           Json?    // full raw response for auditing
  metadata              Json?    // additional context (model version, tokens, etc.)
  createdAt             DateTime @default(now())

  workspace             Workspace @relation(fields: [workspaceId], references: [id])
  promptTestRuns        PromptTestRun[]
}

model PromptTestRun {
  id                    String   @id @default(uuid())
  workspaceId           String
  aiVisibilityResultId  String
  prompt                String
  engine                String
  brand                 String
  competitor            String
  brandTone             String
  compTone              String
  highlighted           Boolean  @default(false)
  createdAt             DateTime @default(now())

  workspace             Workspace          @relation(fields: [workspaceId], references: [id])
  aiVisibilityResult    AIVisibilityResult @relation(fields: [aiVisibilityResultId], references: [id], onDelete: Cascade)
}

model AIFeedback {
  id              String   @id @default(uuid())
  workspaceId     String
  targetType      String   // (signal_analysis, alert, action_plan, cluster)
  targetId        String   // ID of the entity being rated
  action          String   // (accepted, edited, rejected)
  originalOutput  Json?    // the AI output before feedback
  editedOutput    Json?    // user's corrected version (if edited)
  reason          String?  // optional reason for rejection/edit
  userId          String?  // who gave the feedback
  createdAt       DateTime @default(now())

  workspace       Workspace @relation(fields: [workspaceId], references: [id])
}

model AIAnalysisFailureLog {
  id            String   @id @default(uuid())
  workspaceId   String
  signalId      String
  errorMessage  String
  rawAttempt1   String?
  rawAttempt2   String?
  createdAt     DateTime @default(now())

  workspace     Workspace @relation(fields: [workspaceId], references: [id])
  signal        Signal    @relation(fields: [signalId], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id          String   @id @default(uuid())
  userId      String
  tokenHash   String
  expiresAt   DateTime
  revokedAt   DateTime?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id          String   @id @default(uuid())
  userId      String?
  event       String
  metadata    Json?
  createdAt   DateTime @default(now())

  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}
