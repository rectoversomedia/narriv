# Narriv Backend - Environment Variables Template
# Copy this file to .env and fill in your values

# ============================================
# SUPABASE
# ============================================
# Get these from: https://supabase.com/dashboard/project/<project>/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# ============================================
# Authentication (REQUIRED - CHANGE THESE!)
# ============================================
JWT_SECRET=change-this-to-a-random-secret-key
JWT_REFRESH_SECRET=change-this-to-another-random-secret
ACCESS_TOKEN_TTL=1h
REFRESH_TOKEN_TTL_DAYS=30
BCRYPT_SALT_ROUNDS=12

# ============================================
# AI Provider
# ============================================
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key

# ============================================
# Data Collection (Apify)
# ============================================
# Get from: https://console.apify.com/account/integrations
APIFY_TOKEN=your-apify-token
APIFY_API_TOKEN=your-apify-token

# ============================================
# Redis (for BullMQ workers)
# ============================================
# Enable workers on production
ENABLE_WORKERS=false
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379

# ============================================
# Server
# ============================================
PORT=3000
NODE_ENV=development
TRUST_PROXY=loopback
ALLOW_INSECURE_HTTP=false

# ============================================
# CORS
# ============================================
# Development
CORS_ORIGINS=http://localhost:3001
# Production (uncomment and update)
# CORS_ORIGINS=https://www.narrriv.digital,https://narrriv.digital
ALLOW_VERCEL_PREVIEW_ORIGINS=false

# ============================================
# Email (Resend)
# ============================================
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_your-resend-api-key
EMAIL_FROM=Narriv <noreply@yourdomain.com>
EMAIL_ENABLED=true

# ============================================
# App
# ============================================
APP_NAME=Narriv
APP_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3001

# ============================================
# OAuth (Google)
# ============================================
# Get from: https://console.cloud.google.com
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# ============================================
# Logging
# ============================================
LOG_LEVEL=info

# ============================================
# Reports
# ============================================
REPORT_EXPORT_STORAGE_PROVIDER=database
REPORT_EXPORT_URL_TTL_SECONDS=3600

# ============================================
# Worker Settings
# ============================================
AI_ANALYSIS_RETRY_ATTEMPTS=3
AI_ANALYSIS_RETRY_DELAY_MS=3000
INGESTION_RETRY_ATTEMPTS=3
ALERT_DETECTION_RETRY_ATTEMPTS=2
