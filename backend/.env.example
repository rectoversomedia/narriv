# ============================================
# NARRIV BACKEND ENVIRONMENT
# ============================================
# Copy this file to .env and fill in your values
# IMPORTANT: Never commit .env to version control!

# ============================================
# SUPABASE DATABASE
# ============================================
# Get these from: https://supabase.com/dashboard/project/<project>/settings/api
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# ============================================
# DATABASE CONNECTION POOL
# ============================================
# Connection pool settings for Supabase/postgres
DB_POOL_MIN=2
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=10000
DB_PREPARED_STATEMENTS=true

# ============================================
# AUTHENTICATION
# ============================================
# Generate secure secrets: openssl rand -base64 64
# Or: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
JWT_SECRET=<your-256-bit-jwt-secret-here>
JWT_REFRESH_SECRET=<your-256-bit-refresh-secret-here>
ACCESS_TOKEN_TTL=1h
REFRESH_TOKEN_TTL_DAYS=30
BCRYPT_SALT_ROUNDS=12

# ============================================
# OPENAI AI
# ============================================
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key

# ============================================
# APIFY DATA COLLECTION
# ============================================
# Get from: https://console.apify.com/account/integrations
# Optional - required for live data ingestion
APIFY_TOKEN=your-apify-token
APIFY_API_TOKEN=your-apify-token

# ============================================
# RESEND EMAIL
# ============================================
# Get from: https://resend.com/api-keys
# Optional - required for email notifications
RESEND_API_KEY=re_your-resend-api-key
EMAIL_FROM=Narriv <noreply@yourdomain.com>
EMAIL_ENABLED=true

# ============================================
# REDIS (BullMQ Workers)
# ============================================
# Required for background workers
# For local development: redis://localhost:6379
# For Docker: redis://redis:6379
REDIS_URL=redis://localhost:6379
ENABLE_WORKERS=false

# ============================================
# GOOGLE OAUTH
# ============================================
# Get from: https://console.cloud.google.com
# Optional - for Google login
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=3000
NODE_ENV=development
TRUST_PROXY=loopback
ALLOW_INSECURE_HTTP=false

# ============================================
# CORS
# ============================================
# Development
CORS_ORIGINS=http://localhost:3001

# Production (example)
# CORS_ORIGINS=https://app.yourdomain.com,https://yourdomain.com
ALLOW_VERCEL_PREVIEW_ORIGINS=false

# ============================================
# APP URLs
# ============================================
APP_NAME=Narriv
APP_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3001

# ============================================
# SENTRY ERROR TRACKING
# ============================================
# Get from: https://sentry.io/settings/<org>/projects/<project>/keys/
# Optional - for error tracking
SENTRY_DSN=

# ============================================
# REPORTS
# ============================================
REPORT_EXPORT_STORAGE_PROVIDER=database
REPORT_EXPORT_URL_TTL_SECONDS=3600

# ============================================
# WORKER SETTINGS
# ============================================
AI_ANALYSIS_RETRY_ATTEMPTS=3
AI_ANALYSIS_RETRY_DELAY_MS=3000
INGESTION_RETRY_ATTEMPTS=3
ALERT_DETECTION_RETRY_ATTEMPTS=2

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info

# ============================================
# SECURITY
# ============================================
# Session management
SESSION_TIMEOUT_MS=1800000
MAX_CONCURRENT_SESSIONS=3

# Rate limiting
RATE_LIMIT_REDIS_ENABLED=true

# ============================================
# DEVELOPMENT ONLY
# ============================================
# Set to false in production!
EXPOSE_RESET_SECRETS=false
