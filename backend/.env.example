# ==============================================================================
# NARRIV BACKEND ENVIRONMENT VARIABLES
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. SERVER CONFIGURATION
# ------------------------------------------------------------------------------
PORT=3000
NODE_ENV=development

# ------------------------------------------------------------------------------
# 2. DATABASE CONFIGURATION (PostgreSQL Local)
# ------------------------------------------------------------------------------
# Ganti 'postgres', 'password', dan '5432' sesuai dengan konfigurasi PostgreSQL lokal kamu.
# Format: postgresql://[user]:[password]@[host]:[port]/[database_name]?schema=public
DATABASE_URL="postgresql://postgres:4161@localhost:5432/narriv?schema=public"

# ------------------------------------------------------------------------------
# 3. AUTHENTICATION & SECURITY
# ------------------------------------------------------------------------------
# Ganti dengan string acak yang panjang (misal: hasil dari `openssl rand -base64 32`)
JWT_SECRET="super-secret-jwt-key-change-me-in-production"

# ------------------------------------------------------------------------------
# 4. EXTERNAL APIs & SERVICES
# ------------------------------------------------------------------------------
# Apify (Untuk Ingestion Engine - Phase 2)
# Dapatkan dari: https://console.apify.com/account/integrations
APIFY_API_TOKEN="apify_api_token_here"

# OpenAI (Untuk AI Intelligence Engine - Phase 4)
# Dapatkan dari: https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-proj-openai_api_key_here"

# ------------------------------------------------------------------------------
# 5. OPTIONAL / ADVANCED CONFIGURATION (Phase Lanjutan)
# ------------------------------------------------------------------------------
# Redis (Untuk Antrian BullMQ - Ingestion & Alerting)
# REDIS_HOST="localhost"
# REDIS_PORT=6379

# S3 Bucket (Untuk export PDF/CSV & Attachment)
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_REGION=""
# S3_BUCKET_NAME=""

# SMTP (Untuk notifikasi Email)
# SMTP_HOST=""
# SMTP_PORT=587
# SMTP_USER=""
# SMTP_PASS=""
