# Narriv Backend — Environment Variables

# Database
DATABASE_URL=postgresql://narriv:narriv_dev@localhost:5432/narriv
# Required when using docker-compose Postgres locally or on a single-node VPS.
POSTGRES_PASSWORD=change-me

# Authentication
JWT_SECRET=your-jwt-secret-here
JWT_REFRESH_SECRET=your-refresh-secret-here

# AI Provider
OPENAI_API_KEY=sk-your-openai-api-key

# Data Collection
APIFY_TOKEN=your-apify-token

# Redis (for BullMQ workers)
REDIS_URL=redis://localhost:6379
# Optional alternative Redis port when REDIS_URL is not used by a caller.
REDIS_PORT=6379

# Server
PORT=3000
NODE_ENV=development
TRUST_PROXY=loopback
# Production should stay false/blank behind HTTPS. Only use true for controlled internal smoke tests.
ALLOW_INSECURE_HTTP=false

# CORS (comma-separated origins for production)
CORS_ORIGINS=http://localhost:3001
# Production preview origin wildcard is disabled by default.
ALLOW_VERCEL_PREVIEW_ORIGINS=false

# Email (Resend)
RESEND_API_KEY=re_your-resend-api-key
EMAIL_FROM=Narriv <noreply@yourdomain.com>
# Dev reset/verification codes must never be exposed in production.
EXPOSE_RESET_SECRETS=false

# App
APP_NAME=Narriv
APP_URL=http://localhost:3001

# Logging
LOG_LEVEL=info

# Reports
REPORT_EXPORT_STORAGE_PROVIDER=database
REPORT_EXPORT_URL_TTL_SECONDS=3600

# OAuth
FRONTEND_URL=http://localhost:3001
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback
